{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "0.1.0",
  "id": "{{TEAMS_APP_ID}}",
  "developer": {
    "name": "OpenClaw demo",
    "websiteUrl": "https://{{BRIDGE_DOMAIN}}",
    "privacyUrl": "https://{{BRIDGE_DOMAIN}}/health",
    "termsOfUseUrl": "https://{{BRIDGE_DOMAIN}}/health"
  },
  "name": {
    "short": "OpenClaw",
    "full": "OpenClaw on Azure"
  },
  "description": {
    "short": "Chat with OpenClaw running in ACA Sandboxes.",
    "full": "A base 1:1 Teams app that sends text prompts to the OpenClaw Azure Container Apps bridge, wakes the ACA Sandbox Gateway, and returns the OpenClaw response."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#6264A7",
  "bots": [
    {
      "botId": "{{TEAMS_BOT_APP_ID}}",
      "scopes": [
        "personal"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal"
          ],
          "commands": [
            {
              "title": "Ask OpenClaw",
              "description": "Send a text prompt to OpenClaw."
            }
          ]
        }
      ]
    }
  ],
  "validDomains": [
    "{{BRIDGE_DOMAIN}}"
  ]
}
