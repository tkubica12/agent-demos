{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autopilots-on-azure.example/schemas/skill-provenance.schema.json",
  "title": "Autopilots Candidate Improvement provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordId",
    "createdAt",
    "classification",
    "artifactPath",
    "action",
    "title",
    "generalizedLearning",
    "rationale",
    "evidence",
    "confidence",
    "sourceStage",
    "artifact",
    "roleRelease",
    "worker",
    "privacy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "recordId": {
      "type": "string",
      "pattern": "^lr-"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "classification": {
      "enum": [
        "role_skill_improvement",
        "candidate_improvement"
      ]
    },
    "artifactPath": {
      "type": "string",
      "pattern": "^skills/(role|candidates)/[a-z0-9][a-z0-9-]{0,62}$"
    },
    "action": {
      "enum": [
        "create",
        "patch",
        "delete"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "generalizedLearning": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceType",
          "summary"
        ],
        "properties": {
          "sourceType": {
            "enum": [
              "private_session",
              "tool_result",
              "public_source"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sourceStage": {
      "enum": [
        "foreground",
        "dream",
        "background_review",
        "operator"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "beforeHash",
        "afterHash",
        "changedFiles"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "beforeHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "afterHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "changedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "roleRelease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roleBlueprint",
        "release",
        "commit"
      ],
      "properties": {
        "roleBlueprint": {
          "type": "string"
        },
        "release": {
          "type": "string"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workerId",
        "assignmentScope"
      ],
      "properties": {
        "workerId": {
          "type": "string"
        },
        "assignmentScope": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redactionStatus",
        "warnings"
      ],
      "properties": {
        "redactionStatus": {
          "const": "passed"
        },
        "warnings": {
          "type": "array",
          "maxItems": 0
        }
      }
    }
  }
}
